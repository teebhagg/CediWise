{
  "expo": {
    "name": "CediWise",
    "slug": "cediwise-mobile-app",
    "version": "0.2.4",
    "orientation": "portrait",
    "icon": "./assets/images/logo/cediwise-smooth-light-logo.png",
    "scheme": "cediwisemobileapp",
    "updates": {
      "enabled": false
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cediwise.app",
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo/cediwise-smooth-light-logo.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "pan",
      "predictiveBackGestureEnabled": false,
      "package": "com.cediwise.app",
      "googleServicesFile": "./google-services.json",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "blockedPermissions": ["com.google.android.gms.permission.AD_ID"],
      "permissions": [
        "android.permission.NOTIFICATION_LISTENER_SERVICE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo/cediwise-smooth-light-logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo/notification_logo.png",
          "color": "#10b981",
          "defaultChannel": "cediwise-default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo/cediwise-transparent-emerald-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-community/datetimepicker",
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "cediwise"
        }
      ],
      [
        "expo-apple-authentication",
        {
          "iosUrlScheme": "com.cediwise.app"
        }
      ],
      ["expo-build-properties", {
        "ios": {
          "useFrameworks": "static",
          "modularHeaders": true,
          "forceStaticLinking": ["RNFBApp", "RNFBAuth", "RNFBAnalytics"]
        }
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a250eaa5-7771-45ab-8dd4-43d9613a1971"
      }
    },
    "owner": "joshua.ansah"
  }
}
